<?php
/**
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Catalog\Model\Product $product
 */
?>
<div class="product-slider">
    <?php if ($block->getProducts()): ?>
        <ul class="products-grid">
            <?php foreach ($block->getProducts() as $product): ?>
                <?php if ($product->isInStock()): ?>
                    <li class="product-item">
                        <a href="<?php echo $block->escapeHtml($product->getProductUrl()) ?>">
                            <div class="product-image">
                                <img src="<?php echo $block->escapeHtml($block->getImageUrl($product)) ?>" alt="<?php echo $block->escapeHtml($product->getName()) ?>" />
                            </div>
                            <div class="product-info">
                                <h2 class="product-name"><?php echo $block->escapeHtml($product->getName()) ?></h2>
                                <div class="product-price">
                                    <?php echo $block->escapeHtml($block->getPriceHtml($product)) ?>
                                </div>
                                <button type="button" class="action tocart" onclick="setLocation('<?php echo $block->escapeHtml($block->getAddToCartUrl($product)) ?>')">
                                    <span><?php echo __('Add to Cart') ?></span>
                                </button>
                            </div>
                        </a>
                    </li>
                <?php endif; ?>
            <?php endforeach; ?>
        </ul>
    <?php else: ?>
        <p><?php echo __('No products available.') ?></p>
    <?php endif; ?>
</div>